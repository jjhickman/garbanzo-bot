# WhatsApp instance layer. Copy to .env.whatsapp and fill in WhatsApp-specific values.
# Shared provider, monitoring, vector, and integration settings are inherited from .env.

# REQUIRED on WhatsApp: message processing, digests, and recaps refuse to run
# without it (not just DMs/alerts). The bot exits at startup if it is unset.
# Format: <number>@s.whatsapp.net
OWNER_JID=

# Phone number the bot is registered with, including country code.
BOT_PHONE_NUMBER=

# Browser login
WHATSAPP_LOGIN_MODE=web
# Gates only the WhatsApp browser-login page; monitoring/admin now use MONITORING_TOKEN.
WHATSAPP_LOGIN_TOKEN=

# WhatsApp outbound safety (anti-ban)
WHATSAPP_SAFETY_ENABLED=true
WHATSAPP_SAFETY_MAX_PER_MINUTE=5
WHATSAPP_SAFETY_MAX_PER_HOUR=100
WHATSAPP_SAFETY_MAX_PER_DAY=2000
WHATSAPP_SAFETY_MIN_DELAY_MS=2500
WHATSAPP_SAFETY_MAX_DELAY_MS=7000
WHATSAPP_SAFETY_WARMUP_DAYS=10
WHATSAPP_SAFETY_DAY1_LIMIT=2000
WHATSAPP_SAFETY_AUTO_PAUSE_AT=medium

# WhatsApp event reminders
EVENT_REMINDERS_ENABLED=true
EVENT_REMINDER_LEAD_MINUTES=120
