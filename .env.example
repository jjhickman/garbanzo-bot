# Copy .env.example to .env for shared provider, monitoring, vector, and integration values.
# Copy .env.discord.example to .env.discord and/or .env.whatsapp.example to .env.whatsapp for each instance.
# Set COMPOSE_PROFILES in .env to pick discord, whatsapp, both, and optional monitoring.

# ── Compose profiles ─────────────────────────
COMPOSE_PROFILES=discord
# COMPOSE_PROFILES=whatsapp
# COMPOSE_PROFILES=discord,whatsapp
# Append ,monitoring to any deployment shape to add Prometheus and Grafana.

# ── AI providers ─────────────────────────────
# Configure at least one provider named in AI_PROVIDER_ORDER.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
AI_PROVIDER_ORDER=openai,anthropic

# Optional model overrides
OPENAI_MODEL=gpt-5.4-mini
# OPENAI_REASONING_EFFORT=low
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_PROMPT_CACHING=true
GEMINI_MODEL=gemini-1.5-flash
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Optional pricing overrides for cost tracking (USD per 1M tokens).
# OPENAI_PRICING_INPUT_PER_M=0.75
# OPENAI_PRICING_OUTPUT_PER_M=4.5
# ANTHROPIC_PRICING_INPUT_PER_M=1.0
# ANTHROPIC_PRICING_OUTPUT_PER_M=5.0
# GEMINI_PRICING_INPUT_PER_M=0
# GEMINI_PRICING_OUTPUT_PER_M=0

# Global cloud guardrails
CLOUD_MAX_TOKENS=1024
CLOUD_REQUEST_TIMEOUT_MS=30000
# RETRY_ATTEMPT_TIMEOUT_MS=30000

# Native LLM tool calling is off by default.
# AI_TOOL_CALLING=false
# AI_TOOL_MAX_ITERATIONS=3

# AWS Bedrock is optional; add bedrock to AI_PROVIDER_ORDER when configured.
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=
BEDROCK_MAX_TOKENS=1024
# BEDROCK_PRICING_INPUT_PER_M=0
# BEDROCK_PRICING_OUTPUT_PER_M=0

# ── Monitoring and app metadata ──────────────
# Gates /metrics, /admin, Grafana admin fallback, and Prometheus scrapes.
# Generate a long random value before enabling the monitoring profile.
MONITORING_TOKEN=
METRICS_ENABLED=false
# Optional: override the Grafana admin password instead of using MONITORING_TOKEN.
# GRAFANA_ADMIN_PASSWORD=

LOG_LEVEL=info
APP_VERSION=3.3.0

# ── Ollama ───────────────────────────────────
# Containers reach a host Ollama server through host.docker.internal.
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=qwen3:8b

# ── Vector memory ────────────────────────────
# Native runs default to loopback; docker-compose.yml pins QDRANT_URL=http://qdrant:6333.
VECTOR_STORE=qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=garbanzo_memory
QDRANT_API_KEY=
VECTOR_EMBEDDING_PROVIDER=openai
VECTOR_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_EMBEDDING_DIMENSIONS=1536
VECTOR_EMBEDDING_TIMEOUT_MS=12000
VECTOR_EMBEDDING_MAX_CHARS=4000

# ── Shared integrations ──────────────────────
# Weather (Google Cloud Weather + Geocoding APIs)
GOOGLE_API_KEY=

# Public transit (MBTA v3)
MBTA_API_KEY=

# News search
NEWSAPI_KEY=

# Web search provider priority: firecrawl > brave > google > searxng.
FIRECRAWL_API_KEY=
BRAVE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
SEARXNG_BASE_URL=
# WEB_SEARCH_PROVIDER=firecrawl

# Optional owner links/messages
GITHUB_SPONSORS_URL=
PATREON_URL=
KOFI_URL=
SUPPORT_CUSTOM_URL=
SUPPORT_MESSAGE=

# Optional feedback -> GitHub issue automation
GITHUB_ISSUES_TOKEN=
GITHUB_ISSUES_REPO=owner/repo

# ── Shared persistence and memory ────────────
DB_DIALECT=sqlite
# DATABASE_URL=
# POSTGRES_HOST=
# POSTGRES_PORT=5432
# POSTGRES_DB=
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_SSL=false
# POSTGRES_SSL_REJECT_UNAUTHORIZED=false

CONTEXT_SESSION_MEMORY_ENABLED=true
CONTEXT_SESSION_GAP_MINUTES=30
CONTEXT_SESSION_MIN_MESSAGES=4
CONTEXT_SESSION_MAX_RETRIEVED=3
CONTEXT_SESSION_SUMMARY_VERSION=1

# Automatic long-term community memory extraction is off by default.
# MEMORY_AUTO_EXTRACT=false
# MEMORY_AUTO_EXTRACT_MIN_MESSAGES=25
# MEMORY_AUTO_EXTRACT_INTERVAL_MINUTES=360
# MEMORY_AUTO_MAX_FACTS=200

# ── Bridging (v3) ────────────────────────────
# Cross-instance relay between platform instances; off by default.
# See docs/BRIDGING.md. Add broker to COMPOSE_PROFILES when using amqp transport.
# BRIDGE_ENABLED=false
# INSTANCE_ID= (defaults to the platform)
# BRIDGE_TRANSPORT=http
# BRIDGE_BROKER_URL=amqp://garbanzo:<password>@rabbitmq:5672
# BRIDGE_BROKER_USER=garbanzo
# BRIDGE_BROKER_PASSWORD=
# BRIDGE_SUMMARY_INTERVAL_MINUTES=15
# BRIDGE_MAX_TEXT=1500
# SHARED_MEMORY_ENABLED=false
# QDRANT_SHARED_COLLECTION=garbanzo_shared
