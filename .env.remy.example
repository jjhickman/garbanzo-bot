# Remy Discord deployment — copy to .env.remy and fill in real values.
# Do not commit .env.remy.

# Runtime
MESSAGING_PLATFORM=discord
OWNER_JID=discord-owner-placeholder
LOG_LEVEL=info

# Discord app
DISCORD_BOT_TOKEN=
DISCORD_OWNER_ID=
DISCORD_GATEWAY_ENABLED=true
DISCORD_CHANNELS_CONFIG_PATH=config/discord-channels.json

# Band features
BAND_FEATURES_ENABLED=true

# AI providers — configure at least one provider in AI_PROVIDER_ORDER.
AI_PROVIDER_ORDER=openai,anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
BEDROCK_MODEL_ID=

# Vector memory — shared Qdrant service, isolated Remy collection.
VECTOR_STORE=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=remy_memory
VECTOR_EMBEDDING_PROVIDER=openai
VECTOR_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_EMBEDDING_DIMENSIONS=1536

# Health endpoint — distinct from Garbanzo's 3001.
HEALTH_PORT=3002
HEALTH_BIND_HOST=0.0.0.0
