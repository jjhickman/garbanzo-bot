# Garbanzo Telegram instance overrides (.env.telegram)
# Copy to .env.telegram and fill in. Layered on top of the shared .env for
# the telegram compose service / MESSAGING_PLATFORM=telegram native runs.

# From @BotFather (/newbot). Then run /setprivacy -> Disable so the bot can
# see plain messages and apply requireMention itself (docs/PLATFORMS.md).
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user id (ask @userinfobot).
TELEGRAM_OWNER_ID=

# 'configured' (default): only chats enabled in config/telegram-chats.json
# are ingested. 'all' ingests every group the bot is added to.
TELEGRAM_CHAT_SCOPE=configured
