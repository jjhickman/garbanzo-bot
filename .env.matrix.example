# Garbanzo Matrix instance overrides (.env.matrix)
# Copy to .env.matrix and fill in. Layered on top of the shared .env for
# the matrix compose service / MESSAGING_PLATFORM=matrix native runs.

# Base URL of the homeserver the BOT account lives on.
MATRIX_HOMESERVER_URL=

# The bot account's access token (Element: Settings -> Help & About ->
# Advanced -> Access Token). Treat it like a password.
MATRIX_ACCESS_TOKEN=

# YOUR Matrix user id (owner escalations arrive as DMs), e.g. @you:example.org
MATRIX_OWNER_ID=

# 'configured' (default): only rooms enabled in config/matrix-rooms.json are
# ingested. 'all' ingests every room the bot is in. E2EE rooms are not
# supported either way.
MATRIX_CHAT_SCOPE=configured
