# Discord instance layer. Copy to .env.discord and fill in Discord-specific values.
# Shared provider, monitoring, vector, and integration settings are inherited from .env.

# Discord app
DISCORD_BOT_TOKEN=
DISCORD_OWNER_ID=
# Optional when running the Interactions endpoint.
DISCORD_PUBLIC_KEY=
DISCORD_GATEWAY_ENABLED=true

# Discord channel bindings
DISCORD_DIGEST_CHANNEL_ID=
DISCORD_RECAP_CHANNEL_ID=
DISCORD_PRACTICE_CHANNEL_ID=
# Defaults to config/discord-channels.json; override only if you mount a different file.
DISCORD_CHANNELS_CONFIG_PATH=config/discord-channels.json

# Remy / band mode. Set true for band deployments.
BAND_FEATURES_ENABLED=false

# Optional Whisper/Speaches transcription server for dropped audio clips.
# Use a host/LAN IP reachable from the container, not 127.0.0.1.
# WHISPER_URL=http://192.168.1.10:8090

# Optional Remy vector collection override; the shared default lives in .env.
# QDRANT_COLLECTION=remy_memory

# Minutes before a scheduled rehearsal to send the reminder (band mode).
# REHEARSAL_REMINDER_LEAD_MINUTES=120
